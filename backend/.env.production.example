# Production Environment Variables
# Copy this to .env.production and fill in real values

# Environment
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/train_exchange

# MSG91 SMS (Real credentials)
MSG91_AUTH_KEY=your_production_msg91_key
MSG91_SENDER_ID=TRAINSEAT
MSG91_ROUTE=4

# Razorpay (Live credentials - NOT test)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_live_secret_key

# PNR Verification API
PNR_API_PROVIDER=rapidapi
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=pnr-status-indian-railway.p.rapidapi.com

# Security
SECRET_KEY=generate_a_long_random_string_here_minimum_32_characters
OTP_EXPIRY_MINUTES=10

# Database
CLEANUP_HOURS_AFTER_DEPARTURE=2

# Monitoring (Optional)
SENTRY_DSN=https://your-sentry-dsn-here
LOG_LEVEL=INFO
