# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# MSG91 SMS Configuration
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_SENDER_ID=TRAINSEAT
MSG91_ROUTE=4

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
# PNR Verification API
# Options: 'mock' (free, for testing) or 'rapidapi' (paid, real data)
PNR_API_PROVIDER=mock
# Get RapidAPI key from: https://rapidapi.com/hub
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=pnr-status-indian-railway.p.rapidapi.com
# Database Configuration
DB_FOLDER=./data
CLEANUP_HOURS_AFTER_DEPARTURE=2

# Security
OTP_EXPIRY_MINUTES=10
